# 后端环境配置示例
# 复制此文件为 .env 并填入实际值

# JWT密钥 (必须配置，至少32位随机字符串)
JWT_SECRET=your-strong-secret-key-here-at-least-32-characters-long

# 数据库配置
DB_USERNAME=second_market
DB_PASSWORD=your_secure_password
DB_URL=jdbc:postgresql://localhost:5432/second_market

# AI配置
AI_ENABLED=true
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://api.siliconflow.cn/v1/chat/completions
AI_MODEL=Qwen/Qwen2-VL-72B-Instruct

# 安全配置 (开发环境可设为true，生产环境必须设为false
SECURITY_PERMIT_ALL=false

# CORS允许的源 (多个源用逗号分隔，如 http://localhost:5173,https://yourdomain.com)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# 服务器基础URL
SERVER_BASE_URL=http://localhost:8001/api

# 文件上传路径
PROJECT_FILE_UPLOAD_PATH=/path/to/uploads

# Knife4j文档开关
KNIFE4J_ENABLE=false
