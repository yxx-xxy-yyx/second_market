<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.echoofmemories.project.mapper.BrowseHistoryMapper">

    <resultMap id="BrowseHistoryResult" type="com.echoofmemories.project.entity.BrowseHistory">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="productId" column="product_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <association property="product" javaType="com.echoofmemories.project.entity.Product">
            <id property="id" column="p_id"/>
            <result property="title" column="title"/>
            <result property="price" column="price"/>
            <result property="originalPrice" column="original_price"/>
            <result property="images" column="images"/>
            <result property="conditionScore" column="condition_score"/>
            <result property="status" column="status"/>
            <result property="schoolId" column="school_id"/>
            <result property="createTime" column="p_create_time"/>
        </association>
    </resultMap>

    <select id="selectHistoryPage" resultMap="BrowseHistoryResult">
        SELECT 
            bh.*,
            p.id as p_id,
            p.title,
            p.price,
            p.original_price,
            p.images,
            p.condition_score,
            p.status,
            p.school_id,
            p.create_time as p_create_time
        FROM browse_history bh
        LEFT JOIN product p ON bh.product_id = p.id
        WHERE bh.user_id = #{userId} AND p.deleted = 0
        <if test="schoolId != null">
            AND p.school_id = #{schoolId}
        </if>
        ORDER BY bh.update_time DESC
    </select>

</mapper>
