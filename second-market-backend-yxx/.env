# 后端环境配置
# 复制此文件为 .env 并填入实际值

# JWT密钥 (必须配置，至少32位随机字符串)
JWT_SECRET=your-super-strong-secret-key-for-jwt-at-least-32-chars

# 数据库配置 (开发环境可以使用H2内存数据库或PostgreSQL
DB_USERNAME=second_market
DB_PASSWORD=your_secure_password
DB_URL=jdbc:h2:mem:testdb;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE;DB_CLOSE_DELAY=-1
DB_DRIVER=org.h2.Driver

# AI配置
AI_ENABLED=true
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://api.siliconflow.cn/v1/chat/completions
AI_MODEL=Qwen/Qwen2-VL-72B-Instruct

# 安全配置 (开发环境可设为true
SECURITY_PERMIT_ALL=true

# CORS允许的源
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 服务器基础URL
SERVER_BASE_URL=http://localhost:8001/api

# 文件上传路径
PROJECT_FILE_UPLOAD_PATH=./uploads

# Knife4j文档开关
KNIFE4J_ENABLE=true
